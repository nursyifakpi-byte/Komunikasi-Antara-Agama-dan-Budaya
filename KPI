                }
            },
            {
                id: 5,
                title: "STRATEGI MEDIASI DAN PENYELESAIAN KONFLIK",
                rpsCoverage: "4",
                topics: "Konsep Mediasi Konflik Keagamaan.",
                cpmk: "Mahasiswa mampu merancang langkah-langkah mediasi untuk konflik berbasis identitas.",
                keywords: ["Mediasi", "Resolusi Konflik", "Active Listening", "Common Ground"],
                apersepsi: "Studi kasus singkat tentang konflik pendirian rumah ibadah di Indonesia dan peran FKUB.",
                uraian: "Mempelajari tahapan mediasi pihak ketiga. Berpindah dari pendekatan konfrontatif ke pendekatan kolaboratif berbasis pencarian kebutuhan mendasar (needs) di balik posisi (positions) yang berseberangan.",
                hasRolePlay: true,
                rolePlayData: {
                    title: "ROLE PLAY 3: Sidang Mediasi Desa",
                    scenario: "Terjadi sengketa batas lahan antara tempat ibadah A dan warga sekitar. Suasana memanas karena isu agraria dibawa ke ranah sentimen agama.",
                    roles: "Pengurus Tempat Ibadah, Perwakilan Warga, dan Mahasiswa KPI (sebagai Mediator independen dari FKUB).",
                    instruction: "Mediator harus mendemonstrasikan teknik 'Active Listening', meredakan emosi, dan mengarahkan diskusi untuk mencari 'Common Ground' (kepentingan bersama)."
                }
            },
            {
                id: 6,
                title: "HUMANISME DAN PERDAMAIAN GLOBAL",
                rpsCoverage: "14",
                topics: "Pilar Humanisme, Universalisme, Kesatuan, dan Perdamaian.",
                cpmk: "Mahasiswa mampu mensintesis seluruh materi menjadi visi perdamaian yang kokoh.",
                keywords: ["Global Peace", "Human Dignity", "Unity in Diversity"],
                apersepsi: "Membedah dokumen 'Human Fraternity' (Persaudaraan Manusia) yang ditandatangani tokoh-tokoh agama dunia (Paus Fransiskus & Imam Besar Al-Azhar).",
                uraian: "Puncak dari mata kuliah. Menyatukan pemahaman teoretis dan keterampilan praktis untuk mempromosikan martabat kemanusiaan di atas perbedaan dogmatis.",
                hasRolePlay: false,
                evalData: "Proyek Akhir: Membuat video kampanye media sosial berdurasi 60 detik tentang 'Indahnya Keberagaman di Indonesia' dengan menerapkan teori-teori (akulturasi, dekonstruksi stereotip, etika inklusif) yang telah dipelajari."
            }
        ];

        // 2. Application State & DOM Elements
        let activeModuleId = null;
        const listContainer = document.getElementById('module-list-container');
        const emptyState = document.getElementById('empty-state');
        const detailContent = document.getElementById('detail-content');

        // Detail elements
        const dNum = document.getElementById('detail-unit-num');
        const dTitle = document.getElementById('detail-title');
        const dKeywords = document.getElementById('detail-keywords');
        const dCpmk = document.getElementById('detail-cpmk');
        const dApersepsi = document.getElementById('detail-apersepsi');
        const dUraian = document.getElementById('detail-uraian');
        
        // Activity elements
        const dActivityCont = document.getElementById('detail-activity-container');
        const aTitle = document.getElementById('activity-title');
        const aScenario = document.getElementById('activity-scenario');
        const aRolesCont = document.getElementById('activity-roles-container');
        const aRoles = document.getElementById('activity-roles');
        const aInst = document.getElementById('activity-instruction');

        // Eval element
        const dEvalCont = document.getElementById('detail-eval-container');
        const dEvalText = document.getElementById('eval-text');

        // 3. UI Generation Logic
        function renderModuleList() {
            listContainer.innerHTML = '';
            curriculumData.forEach(mod => {
                const item = document.createElement('div');
                item.className = `module-card p-4 border-b border-stone-100 flex flex-col gap-1`;
                item.onclick = () => selectModule(mod.id);
                item.dataset.id = mod.id;

                // Icons logic based on content
                let icon = '📘';
                if(mod.hasRolePlay) icon = '🎭';
                if(mod.id === 6) icon = '🌍';

                item.innerHTML = `
                    <div class="flex justify-between items-center text-xs font-bold text-stone-500 uppercase tracking-wide">
                        <span>Unit ${mod.id}</span>
                        <span>Materi RPS: ${mod.rpsCoverage}</span>
                    </div>
                    <div class="font-bold text-stone-800 text-base leading-tight">${icon} ${mod.title}</div>
                    <div class="text-xs text-stone-500 truncate mt-1">${mod.topics}</div>
                `;
                listContainer.appendChild(item);
            });
        }

        function selectModule(id) {
            // Update state & list styling
            activeModuleId = id;
            document.querySelectorAll('.module-card').forEach(el => {
                if(parseInt(el.dataset.id) === id) {
                    el.classList.add('active');
                } else {
                    el.classList.remove('active');
                }
            });

            const mod = curriculumData.find(m => m.id === id);
            if(!mod) return;

            // Animate transition out
            detailContent.classList.remove('opacity-100');
            emptyState.style.display = 'none';

            setTimeout(() => {
                // Populate data
                dNum.textContent = `Unit ${mod.id} • (Materi RPS: ${mod.rpsCoverage})`;
                dTitle.textContent = mod.title;
                
                // Keywords
                dKeywords.innerHTML = mod.keywords.map(kw => 
                    `<span class="bg-stone-100 text-stone-600 border border-stone-200 text-xs px-2 py-1 rounded-full uppercase tracking-wider">${kw}</span>`
                ).join('');

                dCpmk.textContent = mod.cpmk;
                
                // Add bold formatting to subheadings inside text if needed, but plain text is fine based on prompt
                dApersepsi.textContent = mod.apersepsi;
                dUraian.innerHTML = `<strong>Topik Utama:</strong> ${mod.topics}<br><br>${mod.uraian}`;

                // Handle Role Play conditional display
                if(mod.hasRolePlay) {
                    dActivityCont.classList.remove('hidden');
                    aTitle.textContent = mod.rolePlayData.title;
                    aScenario.textContent = mod.rolePlayData.scenario;
                    if(mod.rolePlayData.roles) {
                        aRolesCont.style.display = 'block';
                        aRoles.textContent = mod.rolePlayData.roles;
                    } else {
                        aRolesCont.style.display = 'none';
                    }
                    aInst.textContent = mod.rolePlayData.instruction;
                } else {
                    dActivityCont.classList.add('hidden');
                }

                // Handle Final Eval conditional display
                if(mod.evalData) {
                    dEvalCont.classList.remove('hidden');
                    dEvalText.textContent = mod.evalData;
                } else {
                    dEvalCont.classList.add('hidden');
                }

                // Show content
                detailContent.classList.remove('hidden');
                // Small delay to allow display:block to apply before animating opacity
                requestAnimationFrame(() => {
                    detailContent.classList.add('opacity-100');
                });

            }, 200); // 200ms matches transition duration
        }

        // 4. Chart Validations & Implementations (Chart.js)
        function initCharts() {
            // Chart 1: Radar Chart for Rubrics
            const ctxRadar = document.getElementById('rubricChart').getContext('2d');
            new Chart(ctxRadar, {
                type: 'radar',
                data: {
                    labels: [
                        ['Empati &', 'Penguasaan Peran'], 
                        ['Kecakapan', 'Komunikasi'], 
                        ['Resolusi', 'Masalah'], 
                        ['Etika', 'Komunikasi']
                    ], // Array of arrays handles wrapping inherently in Chart.js
                    datasets: [{
                        label: 'Target Capaian Ideal (Skor Maks: 4)',
                        data: [4, 4, 4, 4],
                        backgroundColor: 'rgba(13, 148, 136, 0.2)', // Teal 600 with opacity
                        borderColor: 'rgba(13, 148, 136, 1)',
                        pointBackgroundColor: 'rgba(217, 119, 6, 1)', // Amber 600
                        pointBorderColor: '#fff',
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: 'rgba(217, 119, 6, 1)',
                        borderWidth: 2,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false, // CRITICAL for container fit
                    scales: {
                        r: {
                            angleLines: { color: 'rgba(0, 0, 0, 0.1)' },
                            grid: { color: 'rgba(0, 0, 0, 0.1)' },
                            pointLabels: {
                                font: { family: "'Inter', sans-serif", size: 11, weight: 'bold' },
                                color: '#444'
                            },
                            ticks: {
                                beginAtZero: true,
                                max: 4,
                                stepSize: 1,
                                display: false // Hide numbers to make it look cleaner, tooltip handles data
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { font: { family: "'Inter', sans-serif", size: 12 } }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(28, 25, 23, 0.9)', // Stone 900
                            titleFont: { family: "'Inter', sans-serif" },
                            bodyFont: { family: "'Inter', sans-serif" },
                            callbacks: {
                                label: function(context) {
                                    return `Skor Target: ${context.raw} / 4`;
                                }
                            }
                        }
                    }
                }
            });

            // Chart 2: Conceptual Bar Chart (Evolution of Communication Complexity)
            const ctxBar = document.getElementById('evolutionChart').getContext('2d');
            
            // Custom plugin to wrap long labels if they were a single string, 
            // but we'll use arrays for x-axis labels to force wrapping easily.
            const evolutionLabels = [
                ['Era Primitif', '(Simbolik Dasar)'], 
                ['Era Tradisional', '(Kearifan Lokal)'], 
                ['Era Modern', '(Media Massa)'], 
                ['Era Post-Modern', '(Digital & AI)']
            ];

            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: evolutionLabels,
                    datasets: [
                        {
                            label: 'Kompleksitas Pesan/Media',
                            data: [20, 45, 75, 100],
                            backgroundColor: 'rgba(13, 148, 136, 0.8)', // Teal
                            borderRadius: 4
                        },
                        {
                            label: 'Potensi Hambatan (Noise)',
                            data: [15, 30, 60, 95],
                            backgroundColor: 'rgba(217, 119, 6, 0.8)', // Amber
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false, // CRITICAL
                    indexAxis: 'y', // Horizontal bar chart looks better for timelines/progressions
                    scales: {
                        x: {
                            beginAtZero: true,
                            max: 110,
                            ticks: { display: false }, // Conceptual, so exact numbers don't matter visually
                            grid: { display: false },
                            title: { display: true, text: 'Tingkat Kompleksitas (Konseptual)' }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { font: { family: "'Inter', sans-serif", size: 11 } }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { boxWidth: 12, font: { family: "'Inter', sans-serif", size: 11 } }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(28, 25, 23, 0.9)',
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) label += ': ';
                                    if(context.raw === 100 || context.raw === 95) label += "Sangat Tinggi";
                                    else if(context.raw >= 60) label += "Tinggi";
                                    else if(context.raw >= 30) label += "Sedang";
                                    else label += "Rendah";
                                    return label;
                                }
                            }
                        }
                    }
                }
            });
        }

        // 5. Initialization
        document.addEventListener('DOMContentLoaded', () => {
            renderModuleList();
            initCharts();
            
            // Optionally auto-select first module, but empty state is better for exploration discovery
            // selectModule(1); 
        });

    </script>
</body>
</html>
