                    <!-- REQUIRED CHART CONTAINER WITH EXACT RULES -->
                    <div class="chart-container">
                        <canvas id="rubricChart"></canvas>
                    </div>

                    <div class="mt-6 grid grid-cols-2 gap-4 text-sm">
