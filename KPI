                topics: "Pengertian, Teori Dasar, dan Evolusi Budaya (Primitif ke Post-Modern).",
                cpmk: "Mahasiswa mampu menjelaskan definisi komunikasi antaragama/budaya dan memetakan sejarah perkembangannya.",
                keywords: ["Intercultural Communication", "Linear Theory", "Post-Modernism"],
                apersepsi: "Menampilkan dua gambar komparatif: Suku pedalaman yang berkomunikasi melalui asap vs. masyarakat urban yang menggunakan aplikasi translasi AI. Pertanyaan Pemantik: Apakah esensi komunikasi berubah seiring majunya teknologi?",
                uraian: "Objek kajian utama adalah hubungan timbal balik antara pesan dan konteks budaya/iman. Memahami evolusi budaya berarti menelaah bagaimana masyarakat bergeser dari kearifan lokal tradisional menuju kompleksitas masyarakat digital (Post-modern).",
                hasRolePlay: false
            },
            {
                id: 2,
                title: "IDENTITAS, RAS, DAN SISTEM KEPERCAYAAN",
                rpsCoverage: "6, 7, 12",
                topics: "Ras, Suku, Bangsa, Pandangan Hidup, dan Proses Perubahan Budaya.",
                cpmk: "Mahasiswa mampu menguraikan peran identitas etnik dan sistem kepercayaan dalam membentuk pola komunikasi.",
                keywords: ["Ethnic Identity", "Worldview", "Asimilasi", "Akulturasi"],
                apersepsi: "Diskusi tentang fenomena 'Blasteran' atau 'Indo' di Indonesia dan bagaimana mereka menegosiasikan identitas budayanya dalam keseharian.",
                uraian: "Sistem Kepercayaan (Agama) berfungsi sebagai 'kacamata' dalam melihat dunia. Menelaah proses perubahan: Mengapa ada kebudayaan yang lebur sepenuhnya (Asimilasi) dan ada yang berpadu berdampingan tanpa hilang aslinya (Akulturasi).",
                hasRolePlay: false
            },
            {
                id: 3,
                title: "HAMBATAN & PSIKOLOGI KOMUNIKASI INTERKULTURAL",
                rpsCoverage: "9, 10, 13",
                topics: "Hambatan (Noise), Culture Shock, Stereotip, Prasangka, dan Rasisme.",
                cpmk: "Mahasiswa mampu mengidentifikasi hambatan psikologis dan sosial dalam interaksi lintas budaya.",
                keywords: ["Noise", "Culture Shock", "Stereotip", "Prasangka"],
                apersepsi: "Analisis mengenai mengapa pesan yang sama bisa diartikan sebagai pujian di satu budaya, namun hinaan di budaya lain.",
                uraian: "Mendalami filter psikologis yang menghalangi komunikasi efektif. Fokus pada pengenalan dan dekonstruksi prasangka serta rasisme yang sering tidak disadari.",
                hasRolePlay: true,
                rolePlayData: {
                    title: "ROLE PLAY 1: Simulasi Culture Shock",
                    scenario: "Seorang mahasiswa dari desa terpencil di Indonesia Timur mendapat beasiswa ke universitas besar di Jakarta atau luar negeri.",
                    roles: "Mahasiswa Baru (mengalami culture shock), Teman Sekelas (memberi stereotip), dan Dosen (sebagai mediator).",
                    instruction: "Tunjukkan secara teatrikal bagaimana 'Noise' berupa perbedaan bahasa daerah, aksen, dan kebiasaan sehari-hari memicu kesalahpahaman akut."
                }
            },
            {
                id: 4,
                title: "ETIKA, MEDIA, DAN PUBLIC SPEAKING",
                rpsCoverage: "3, 11",
                topics: "Etika Komunikasi, Media Antarumat Beragama, dan Praktik Public Speaking.",
                cpmk: "Mahasiswa mampu mempraktikkan komunikasi publik yang santun dan etis di hadapan audiens yang beragam.",
                keywords: ["Etika Komunikasi", "Inklusivitas", "Public Speaking"],
                apersepsi: "Menganalisis cuplikan pidato tokoh dunia yang berhasil menyatukan perbedaan vs pidato yang memicu kontroversi.",
                uraian: "Fokus pada pemilihan diksi, sensitivitas budaya, dan pemanfaatan media untuk menyebarkan narasi positif antarumat beragama.",
                hasRolePlay: true,
                rolePlayData: {
                    title: "ROLE PLAY 2: Pidato Kerukunan",
                    scenario: "Mahasiswa berperan sebagai perwakilan pemuda Islam yang diminta memberi sambutan dalam acara peresmian taman perdamaian yang dihadiri berbagai tokoh agama.",
                    roles: "Orator (Pemuda), Audiens Lintas Iman.",
